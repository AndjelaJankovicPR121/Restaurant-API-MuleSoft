	<flow name="create-order-flow" doc:id="1a5677d1-4bae-4d3e-8247-8276e3d0a8f2" >
		<http:listener doc:name="Listener" doc:id="ad4c2aea-0feb-45cf-ab92-8eed0d6362de" config-ref="HTTP_Listener_config" path="/orders" allowedMethods="POST">
			<http:response statusCode="#[vars.httpStatus default 201]" />
		</http:listener>
		<set-variable value='#[%dw 2.0&#10;output application/java&#10;---&#10;payload ++ {&#10;    orderStatus: "new",&#10;    amount: payload.amount * 2&#10;}]' doc:name="Set Variable" doc:id="6cbfff4e-a827-47f9-8a9f-5d1384a1fbb4" variableName="orderData"/>
		<file:write doc:name="Write" doc:id="5cbc9367-be48-42b4-a26b-a6e5a7a43635" path='#["internalERP/internalERP_" ++ (now() as String {format: "yyyyMMddHHmmssSSS"}) ++ ".xml"]' config-ref="File_Config">
			<file:content ><![CDATA[#[%dw 2.0
output application/xml
---
{
    order: {
        customerID: vars.orderData.customerID,
        tableID: vars.orderData.tableID,
        employeeID: vars.orderData.employeeID,
        orderName: vars.orderData.orderName,
        orderStatus: vars.orderData.orderStatus,
        amount: vars.orderData.amount,
        totalAmount: vars.orderData.totalAmount
    }
}]]]></file:content>
		</file:write>
		<choice doc:name="Choice" doc:id="93122ebc-0a23-491b-a55b-22ae55783716" >
			<when expression="#[payload.amount &gt; 100]">
				<file:write doc:name="Write" doc:id="15bb7778-3206-4cc0-bdf4-a3e8a7153edd" path='#["chineseERP/chineseERP_" ++ (now() as String {format: "yyyyMMddHHmmssSSS"}) ++ ".json"]' config-ref="File_Config">
					<file:content ><![CDATA[#[%dw 2.0
output application/json
---
vars.orderData]]]></file:content>
				</file:write>
				<db:insert doc:name="Insert" doc:id="49d69838-eded-4724-803e-d41f7eb18842" config-ref="Database_Config">
					<db:sql><![CDATA[INSERT INTO orders
(
    customer_id,
    table_id,
    employee_id,
    order_name,
    order_status,
    amount,
    total_amount
)
VALUES
(
    :customerId,
    :tableId,
    :employeeId,
    :orderName,
    :orderStatus,
    :amount,
    :totalAmount
)]]></db:sql>
					<db:input-parameters><![CDATA[#[{
    customerId: vars.orderData.customerID,
    tableId: vars.orderData.tableID,
    employeeId: vars.orderData.employeeID,
    orderName: vars.orderData.orderName,
    orderStatus: vars.orderData.orderStatus,
    amount: vars.orderData.amount,
    totalAmount: vars.orderData.totalAmount
}]]]></db:input-parameters>
				</db:insert>
				<ee:transform doc:name="Transform Message" doc:id="4af1c0be-77d7-44a6-8978-d42fac8f6dcb">
					<ee:message>
						<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    message: "Large order created successfully. Amount was multiplied by 2."
}]]></ee:set-payload>
					</ee:message>
				</ee:transform>
			</when>
			<otherwise >
				<db:insert doc:name="Insert" doc:id="cf87901b-5699-4b1d-9954-a0dce439d2a9" config-ref="Database_Config">
					<db:sql ><![CDATA[INSERT INTO orders
(
    customer_id,
    table_id,
    employee_id,
    order_name,
    order_status,
    amount,
    total_amount
)
VALUES
(
    :customerId,
    :tableId,
    :employeeId,
    :orderName,
    'new',
    :amount,
    :totalAmount
)]]></db:sql>
					<db:input-parameters ><![CDATA[#[{
    customerId: vars.orderData.customerID,
