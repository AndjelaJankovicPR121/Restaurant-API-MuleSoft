	<flow name="get-customers-flow" doc:id="6cc671f6-b735-4e67-85d1-d5645991b164" >
		<http:listener doc:name="Listener" doc:id="1f544244-61c5-4e1d-b7c8-32e70685cbcd" config-ref="HTTP_Listener_config" path="/customers">
			<http:response statusCode="#[vars.httpStatus default 200]" />
		</http:listener>
		<choice doc:name="Choice" doc:id="04d8f121-4378-4da9-b346-60c2819c13e2" >
			<when expression='#[attributes.headers.active != null and !(attributes.headers.active == "true" or attributes.headers.active == "false")]'>
				<set-variable value="400" doc:name="Set Variable" doc:id="79b103d2-81e4-4200-b020-b467ac5bdf0d" variableName="httpStatus"/>
				<ee:transform doc:name="Transform Message" doc:id="53da510a-4f27-4d88-b21e-7d5809f1c05a" >
					<ee:message >
						<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
  message: "Header active mora imati vrednost true ili false."
}]]></ee:set-payload>
					</ee:message>
				</ee:transform>
			</when>
			<otherwise>
				<db:select doc:name="Select" doc:id="dcbe7372-4943-421d-bbe9-e3f864be6a6d" config-ref="Database_Config">
			<db:sql><![CDATA[SELECT 
    customer_id AS customerID,
    first_name AS firstName,
    last_name AS lastName,
    username,
    email,
    phone,
    date_of_birth AS dateOfBirth,
    gender,
    active,
    updated_at AS updatedAt
FROM customers
WHERE (:active IS NULL OR active = :active)]]></db:sql>
			<db:input-parameters><![CDATA[#[{
    active: if (attributes.headers.active == null)
                null
            else if (attributes.headers.active == "true")
                true
            else if (attributes.headers.active == "false")
                false
            else
                null
}]]]></db:input-parameters>
		</db:select>
				<ee:transform doc:name="Transform Message" doc:id="46c5c9ae-faeb-44a5-8a8d-685395685e2f">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
			</ee:message>
		</ee:transform>
			</otherwise>
		</choice>
	</flow>
