              }

/restaurant-tables:
  get:
    description: Returns all restaurant tables.
    responses:
      200:
        body:
          application/json:
            type: RestaurantTable[]
            example:
              [
                {
                  "tableID": 1,
                  "tableNumber": 1,
                  "capacity": 2,
                  "status": "available"
                }
              ]

  post:
    description: Creates a new restaurant table.
    body:
      application/json:
        type: RestaurantTable
        example:
          {
            "tableNumber": 10,
            "capacity": 4,
            "status": "available"
          }
    responses:
      201:
        body:
          application/json:
            type: Message
            example:
              {
                "message": "Restaurant table created successfully."
              }

/restaurant-tables/{id}:
  uriParameters:
    id:
      type: integer
      required: true

  get:
    description: Returns restaurant table by ID.
    responses:
      200:
        body:
          application/json:
            type: RestaurantTable
            example:
              {
                "tableID": 1,
                "tableNumber": 1,
                "capacity": 2,
                "status": "available"
              }
      404:
        body:
          application/json:
            type: Message
            example:
              {
                "message": "Restaurant table with ID 999 does not exist."
              }

  put:
    description: Updates restaurant table by ID.
    body:
      application/json:
        type: RestaurantTable
        example:
          {
            "tableNumber": 1,
            "capacity": 5,
            "status": "reserved"
          }
    responses:
      200:
        body:
          application/json:
            type: Message
            example:
              {
                "message": "Restaurant table updated successfully."
              }
      404:
        body:
          application/json:
            type: Message
            example:
              {
                "message": "Restaurant table with ID 999 does not exist."
              }

  delete:
    description: Deletes restaurant table by ID.
    responses:
      200:
        body:
          application/json:
            type: Message
            example:
              {
                "message": "Restaurant table deleted successfully."
              }
      404:
        body:
          application/json:
            type: Message
            example:
              {
                "message": "Restaurant table with ID 999 does not exist."
              }

